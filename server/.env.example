# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Matches docker-compose.yml
DATABASE_URL="postgresql://fluxion:fluxion@localhost:5432/fluxion?schema=public"
PORT=4000

JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"
CLIENT_URL="http://localhost:5173"

# Redis powers the BullMQ run queue and the Socket.IO realtime adapter (matches docker-compose.yml)
REDIS_URL="redis://localhost:6379"

# Distributed execution tuning
QUEUE_MAX_ATTEMPTS=3       # retries (incl. first attempt) before dead-lettering a run
QUEUE_BACKOFF_MS=1000      # base delay for exponential backoff between retries
WORKER_CONCURRENCY=5       # max runs a single worker executes simultaneously

# LLM provider layer: none | ollama | openai (default dev: ollama)
LLM_PROVIDER="ollama"
