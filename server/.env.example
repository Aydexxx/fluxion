# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Matches docker-compose.yml
DATABASE_URL="postgresql://fluxion:fluxion@localhost:5432/fluxion?schema=public"
PORT=4000

JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="7d"
CLIENT_URL="http://localhost:5173"

# Redis powers the BullMQ run queue and the Socket.IO realtime adapter (matches docker-compose.yml)
REDIS_URL="redis://localhost:6379"

# Distributed execution tuning
QUEUE_MAX_ATTEMPTS=3       # retries (incl. first attempt) before dead-lettering a run
QUEUE_BACKOFF_MS=1000      # base delay for exponential backoff between retries
WORKER_CONCURRENCY=5       # max runs a single worker executes simultaneously

# LLM provider layer: none | ollama | openai (default dev: ollama)
LLM_PROVIDER="ollama"

# Master key for encrypting credential secrets at rest (AES-256-GCM).
# Must decode (base64 or 64-char hex) to exactly 32 bytes. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this key makes all existing stored credentials unreadable. See README.
CREDENTIALS_KEY="2mLPAPxi2jTwoTjIR2QeSFgD1ZU2t2vBX5183NZIb54="

# Per-node execution timeouts (ms) — a node may lower these via its own config
NODE_HTTP_TIMEOUT_MS=30000
NODE_AI_TIMEOUT_MS=60000

# Rate limiting (auth + public webhooks). Disabled automatically under test.
RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_MS=900000   # 15 min
AUTH_RATE_LIMIT_MAX=50
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000 # 1 min
WEBHOOK_RATE_LIMIT_MAX=120

# Structured logging level: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL="info"
