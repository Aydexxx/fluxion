// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  owner
  admin
  editor
  viewer
}

enum InviteStatus {
  pending
  accepted
  declined
}

enum RunTrigger {
  manual
  webhook
  schedule
  api
}

enum ExecutionStatus {
  queued
  running
  success
  failed
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  ownedWorkspaces Workspace[]
  memberships     WorkspaceMember[]
  notifications   Notification[]
}

/// Multi-tenant container; everything else (workflows, credentials) is scoped to a workspace.
model Workspace {
  id      String @id @default(cuid())
  name    String
  ownerId String

  owner       User              @relation(fields: [ownerId], references: [id])
  members     WorkspaceMember[]
  invites     Invite[]
  workflows   Workflow[]
  credentials Credential[]
  auditLogs   AuditLog[]
  folders     Folder[]
  tags        Tag[]
  variables   WorkspaceVariable[]
  secrets     WorkspaceSecret[]
  apiKeys     ApiKey[]

  @@index([ownerId])
}

/// A pending/answered invitation to join a workspace, keyed by email so it works
/// whether or not the invitee has an account yet. An existing user sees it under
/// their pending invites and accepts; a new user's invites resolve once they sign
/// up with the matching email. One active invite per (workspace, email).
model Invite {
  id            String       @id @default(cuid())
  workspaceId   String
  /// Normalized (lowercased) invitee email — the join key for account-less invites.
  email         String
  role          WorkspaceRole @default(viewer)
  status        InviteStatus  @default(pending)
  /// Denormalized inviter name, so the invitee's list needs no extra joins.
  invitedByName String?
  createdAt     DateTime     @default(now())
  respondedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([email])
  @@index([workspaceId])
}

/// RBAC join table between User and Workspace.
model WorkspaceMember {
  userId      String
  workspaceId String
  role        WorkspaceRole @default(viewer)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
  @@index([workspaceId])
}

model Workflow {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  isActive    Boolean  @default(true)
  /// Unguessable token for this workflow's inbound webhook URL (/webhooks/:token).
  webhookToken String? @unique
  /// The DAG being edited. Editing only ever touches the draft; it never runs in production.
  draftDefinition Json
  /// The DAG that actually runs for active webhook/schedule triggers. Null until first publish.
  publishedDefinition Json?
  /// Optional failure-alert config: `{ channel, credentialId, to? }`. Null = no alerts.
  failureNotify Json?
  /// Optional folder this workflow is filed under, for organization at scale. Null = unfiled.
  folderId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder    Folder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags      WorkflowTag[]
  runs      WorkflowRun[]
  versions  WorkflowVersion[]

  @@index([workspaceId])
  @@index([folderId])
}

/// A flat (non-nested) grouping of workflows within a workspace, for organizing
/// a growing list. Deleting a folder un-files its workflows rather than deleting
/// them (see Workflow.folder's onDelete: SetNull).
model Folder {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflows Workflow[]

  @@index([workspaceId])
}

/// A reusable, workspace-scoped label. Names are normalized (trimmed +
/// lowercased) at write time so "Marketing" and "marketing" collapse into one
/// tag instead of fragmenting the filter list.
model Tag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflows WorkflowTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

/// Join table for the Workflow <-> Tag many-to-many.
model WorkflowTag {
  workflowId String
  tagId      String

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([workflowId, tagId])
  @@index([tagId])
}

/// An immutable snapshot taken every time a workflow is published (or rolled back).
/// The newest version (highest `version`) is always the one currently published.
model WorkflowVersion {
  id         String   @id @default(cuid())
  workflowId String
  /// Monotonic per-workflow version number (1, 2, 3 …).
  version    Int
  /// Workflow name at snapshot time, for a self-contained history entry.
  name       String
  /// Short human note, e.g. "Published" or "Rolled back to v3".
  note       String?
  /// Who published it (id + denormalized name so history needs no joins). Null for system/migration entries.
  authorId   String?
  authorName String?
  /// The exact DAG that was promoted to published by this version.
  definition Json
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId])
}

/// One execution of a Workflow.
model WorkflowRun {
  id         String          @id @default(cuid())
  workflowId String
  status     ExecutionStatus @default(queued)
  trigger    RunTrigger
  createdAt  DateTime        @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  error      String?
  payload    Json?
  /// Snapshot of the exact definition this run executes, captured at enqueue time.
  /// Decouples a run from later draft edits, so editing never alters an in-flight run.
  definition Json?
  /// When this run is a replay, the run it was replayed from (kept for lineage).
  replayOfId String?
  /// The user who triggered this run (manual/replay). Null for webhook/schedule
  /// triggers with no human actor — used to notify a run's owner when it fails.
  triggeredById String?
  /// When this run is a nested sub-workflow invocation, the parent run that called it.
  /// Null for top-level runs. Cascades so deleting a parent run removes its nested runs.
  parentRunId String?
  /// The `flow.subworkflow` node in the parent definition that spawned this run (timeline linkage).
  parentNodeId String?

  workflow       Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeExecutions NodeExecution[]
  logs           RunLog[]
  replayOf       WorkflowRun?    @relation("RunReplays", fields: [replayOfId], references: [id], onDelete: SetNull)
  replays        WorkflowRun[]   @relation("RunReplays")
  parentRun      WorkflowRun?    @relation("NestedRuns", fields: [parentRunId], references: [id], onDelete: Cascade)
  nestedRuns     WorkflowRun[]   @relation("NestedRuns")

  @@index([workflowId])
  @@index([createdAt])
  @@index([replayOfId])
  @@index([parentRunId])
  // Keyset pagination on the workspace runs list orders by (createdAt, id) desc.
  @@index([createdAt, id])
}

/// Per-node result inside a WorkflowRun.
model NodeExecution {
  id         String          @id @default(cuid())
  runId      String
  nodeId     String
  status     ExecutionStatus @default(queued)
  input      Json?
  output     Json?
  error      String?
  /// How many attempts the engine made for this node within the run (>=1).
  attempts   Int             @default(1)
  startedAt  DateTime?
  finishedAt DateTime?

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

/// Structured, correlation-scoped log line emitted while a run executes.
/// Streamed live over Socket.IO and retained for the run's observability view.
model RunLog {
  id      String   @id @default(cuid())
  runId   String
  /// Monotonic per-run sequence number, for stable ordering + incremental fetch.
  seq     Int
  level   String
  message String
  /// The node this line concerns, when applicable (null for run-level lines).
  nodeId  String?
  ts      DateTime @default(now())

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, seq])
}

/// Encrypted secret used by workflow nodes (e.g. API keys). `encryptedData` holds the
/// AES-256-GCM packed ciphertext of the credential's JSON fields; raw secrets never leave the server.
model Credential {
  id            String   @id @default(cuid())
  workspaceId   String
  name          String
  type          String
  encryptedData String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

/// An append-only record of a noteworthy workspace event (who did what to what,
/// when). Read-only by design — never updated or deleted except via workspace
/// cascade. The actor + target are denormalized (name alongside id) so the audit
/// view renders with no extra joins and survives the actor/target being removed.
model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  /// The user who performed the action. Null for system-originated events.
  actorId     String?
  /// Denormalized actor name at event time (e.g. "Ada"), or "System".
  actorName   String?
  /// Stable event key, e.g. "member.invited", "workflow.published", "run.failed".
  action      String
  /// What the action concerned: "member" | "workflow" | "credential" | "run" | "invite" | "workspace".
  targetType  String?
  targetId    String?
  /// Denormalized human label for the target (email, workflow name, …).
  targetName  String?
  /// Extra structured context, e.g. `{ from: "viewer", to: "editor" }` for a role change.
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // The audit view paginates by (createdAt, id) desc and filters by actor/action.
  @@index([workspaceId, createdAt])
  @@index([workspaceId, actorId])
  @@index([workspaceId, action])
}

/// A persisted in-app notification addressed to a single user. Survives reload
/// (unlike ephemeral presence) and is also pushed live over the user's Socket.IO
/// channel. `data` carries deep-link context (workspace/run id) for the UI.
model Notification {
  id          String   @id @default(cuid())
  userId      String
  /// Event key: "workspace.invited" | "run.failed" | "role.changed" | "mention".
  type        String
  title       String
  body        String?
  /// Workspace this notification relates to, when applicable (for deep-linking).
  workspaceId String?
  /// Extra structured context (e.g. `{ runId, workflowId }`), for navigation.
  data        Json?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The bell lists newest-first and counts unread per user.
  @@index([userId, createdAt])
  @@index([userId, read])
}

/// A scoped, revocable API key granting programmatic access to a single workspace
/// through the public `/api/v1` surface. Only the SHA-256 hash of the secret is
/// stored — the plaintext is shown exactly once, at creation. `prefix` is a
/// non-secret leading slice kept for display/identification in the management UI.
model ApiKey {
  id            String   @id @default(cuid())
  workspaceId   String
  name          String
  /// SHA-256 (hex) of the full key. Looked up on every authenticated API request.
  hashedKey     String   @unique
  /// Non-secret leading slice of the key (e.g. "flux_AbC123"), safe to display.
  prefix        String
  /// Capability scopes (e.g. "workflows:read", "workflows:run") — the key's RBAC.
  scopes        String[]
  /// Last time the key authenticated a request (throttled writes); null until first use.
  lastUsedAt    DateTime?
  /// Who created it (id + denormalized name), for the management list.
  createdById   String?
  createdByName String?
  /// Soft-revocation timestamp; a revoked key never authenticates again. Null = active.
  revokedAt     DateTime?
  createdAt     DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([hashedKey])
}

/// A reusable, workspace-scoped plain-text value referenced in node configs via
/// `{{ vars.KEY }}`. Unlike a secret, the value is non-sensitive and is returned
/// to the client as-is (e.g. a base URL, an account id, a feature flag).
model WorkspaceVariable {
  id          String   @id @default(cuid())
  workspaceId String
  /// Reference key (identifier-shaped: letters, digits, underscore). Unique per workspace.
  key         String
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

/// A reusable, workspace-scoped secret referenced in node configs via
/// `{{ secrets.KEY }}`. The value is encrypted at rest (AES-256-GCM, same packed
/// format and master key as credentials) and is NEVER returned to the client —
/// only its key is exposed. Decrypted solely at execution time (worker / node test).
model WorkspaceSecret {
  id             String   @id @default(cuid())
  workspaceId    String
  /// Reference key (identifier-shaped). Unique per workspace.
  key            String
  /// AES-256-GCM packed ciphertext (`v1:iv:tag:ciphertext`). Never leaves the server in plaintext.
  encryptedValue String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId])
}
